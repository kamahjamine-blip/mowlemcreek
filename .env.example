# ─── SERVER ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT (change this to a long random string in production) ─────────────
JWT_SECRET=brightpath-change-this-to-a-long-random-string-in-production

# ─── DATABASE ─────────────────────────────────────────────────────────────
DB_PATH=./brightpath.db

# ─── M-PESA (Safaricom Daraja API) ───────────────────────────────────────
# Register at: https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_PASSKEY=your_lipa_na_mpesa_online_passkey
MPESA_SHORTCODE=174379
MPESA_CALLBACK_URL=https://yourdomain.co.ke/api/mpesa/callback
MPESA_ENV=sandbox
# Change MPESA_ENV to 'production' when going live

# ─── SCHOOL INFO ──────────────────────────────────────────────────────────
SCHOOL_NAME=BrightPath Academy
SCHOOL_EMAIL=info@brightpathacademy.co.ke
SCHOOL_PHONE=+254720123456
SCHOOL_ADDRESS=Westlands Road, Nairobi
